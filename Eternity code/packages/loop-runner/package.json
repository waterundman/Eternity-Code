{
  "name": "@eternity-code/loop-runner",
  "version": "1.0.0",
  "description": "Automated coding agent loop runner for OpenCode",
  "type": "module",
  "license": "MIT",
  "bin": {
    "meta": "./dist/cli.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts",
    "./phases": "./src/phases/index.ts",
    "./schema": "./src/schema/index.ts",
    "./llm": "./src/llm/index.ts",
    "./git": "./src/git/index.ts",
    "./tui": "./src/tui/index.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "bun run script/build.ts",
    "dev": "bun run src/cli.ts",
    "test": "bun test --timeout 30000"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@eternity-code/sdk": "workspace:*",
    "@eternity-code/plugin": "workspace:*",
    "@eternity-code/util": "workspace:*",
    "ink": "^5.0.0",
    "react": "^18.2.0",
    "js-yaml": "^4.1.0",
    "simple-git": "^3.22.0",
    "zod": "4.1.8",
    "remeda": "2.26.0",
    "yargs": "^18.0.0",
    "fuzzysort": "^3.1.0",
    "glob": "^10.3.10",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "cli-table3": "^0.6.3",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.2.0",
    "@types/node": "22.13.9",
    "typescript": "5.8.2",
    "@typescript/native-preview": "7.0.0-dev.20251207.1",
    "@tsconfig/node22": "22.0.2"
  }
}
